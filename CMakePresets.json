{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 16, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (no OpenCV hint)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-opencv",
      "displayName": "Windows + OpenCV_DIR",
      "inherits": "default",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "OpenCV_DIR": { "type": "PATH", "value": "$env{OpenCV_DIR}" }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "default",
      "configuration": "Release"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-opencv",
      "configuration": "Release"
    }
  ]
}
